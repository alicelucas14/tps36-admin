</section>

<!-- How to Install Section -->
<section class="py-24 bg-[#000a14] relative overflow-hidden">
    <!-- Ambient glows -->
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[150px] pointer-events-none -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none translate-x-1/2 translate-y-1/2"></div>
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.04] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 relative z-10">

        <!-- Section Label + Title -->
        <div class="text-center mb-14">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-secondary/30 bg-secondary/10 text-secondary text-xs font-bold tracking-[0.15em] uppercase mb-5">
                <i class="fa-solid fa-mobile-screen-button text-[10px]"></i> Installation Guide
            </div>
            <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight leading-tight">
                How to Install <span class="text-[#FFF200] tracking-wide" style="text-shadow: 0 4px 6px rgba(0,0,0,0.5);">Teen Patti <span style="text-shadow: 0 4px 6px rgba(0,0,0,0.5), 0 0 20px rgba(255,242,0,0.8), 0 0 40px rgba(255,242,0,0.4);">Stars</span></span> APK
            </h2>
            <p class="text-slate-400 mt-4 text-base max-w-xl mx-auto">Get started in under 2 minutes. Follow the steps below and watch the video guide.</p>
            <div class="w-20 h-[3px] bg-gradient-to-r from-transparent via-secondary to-transparent mx-auto mt-6 rounded-full"></div>
        </div>

        <!-- Main Card -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 rounded-3xl overflow-hidden border border-secondary/20 shadow-[0_0_80px_rgba(0,0,0,0.9),0_0_0_1px_rgba(0,245,255,0.05)]">

            <!-- LEFT: Steps panel (2/5) -->
            <div class="lg:col-span-2 bg-gradient-to-b from-[#00111f] to-[#000d18] flex flex-col relative">
                <!-- Top accent line -->
                <div class="h-[3px] w-full bg-gradient-to-r from-secondary/0 via-secondary to-secondary/0"></div>

                <div class="p-8 flex flex-col flex-1">
                    <!-- Mini header -->
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-secondary/15 border border-secondary/30 flex items-center justify-center text-secondary">
                            <i class="fa-solid fa-circle-play text-lg"></i>
                        </div>
                        <div>
                            <div class="text-white font-black text-sm tracking-wide">Watch Video</div>
                            <div class="text-secondary/60 text-xs">Click play to get started</div>
                        </div>
                    </div>

                    <p class="text-slate-400 text-sm leading-relaxed mb-8 border-l-2 border-secondary/30 pl-4">
                        Play Teen Patti, Rummy & Lucky Lottery — all in one app. Download now and keep winning every day!
                    </p>

                    <!-- Steps -->
                    <div class="space-y-5 flex-1">
                        <% [
                            { icon: 'fa-download', step: '01', title: 'Download APK', desc: 'Tap the Download button at the top of the page' },
                            { icon: 'fa-shield-halved', step: '02', title: 'Allow Installation', desc: 'Enable "Install from unknown sources" in your phone settings' },
                            { icon: 'fa-file-arrow-down', step: '03', title: 'Install the File', desc: 'Open the downloaded APK file and tap Install' },
                            { icon: 'fa-trophy', step: '04', title: 'Start Winning!', desc: 'Launch the app, register, and claim your bonus' }
                        ].forEach(function(s) { %>
                        <div class="flex items-start gap-4 group">
                            <div class="flex flex-col items-center gap-1 flex-shrink-0">
                                <div class="w-10 h-10 rounded-xl bg-secondary/10 border border-secondary/25 flex items-center justify-center text-secondary group-hover:bg-secondary/20 group-hover:border-secondary/50 transition-all">
                                    <i class="fa-solid <%= s.icon %> text-sm"></i>
                                </div>
                                <div class="text-secondary/30 text-[9px] font-black tracking-widest"><%= s.step %></div>
                            </div>
                            <div class="pt-1">
                                <div class="text-white font-bold text-sm"><%= s.title %></div>
                                <div class="text-slate-500 text-xs leading-relaxed mt-0.5"><%= s.desc %></div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Video panel (3/5) -->
            <div class="lg:col-span-3 bg-[#000810] relative flex flex-col overflow-hidden">
                <!-- Corner accents -->
                <div class="absolute top-0 left-0 w-16 h-16 border-t-2 border-l-2 border-secondary/30 rounded-tl-lg pointer-events-none z-10"></div>
                <div class="absolute bottom-0 right-0 w-16 h-16 border-b-2 border-r-2 border-secondary/30 rounded-br-lg pointer-events-none z-10"></div>

                <!-- Video wrapper -->
                <div class="lazy-video-wrapper-tps w-full relative flex-1">
                    <img
                        class="lazy-video-thumbnail-tps"
                        src="/uploads/teenpattistars_how_to_install.jpg"
                        alt=""
                        width="640"
                        height="360"
                        onerror="this.style.display='none'; document.getElementById('video-no-thumb').style.display='flex';">

                    <!-- Fallback when no thumbnail -->
                    <div id="video-no-thumb" style="display:none; position:absolute; inset:0; background:linear-gradient(135deg,#000d1a,#001a2e); align-items:center; justify-content:center; flex-direction:column; gap:12px;">
                        <i class="fa-solid fa-clapperboard" style="font-size:3rem; color:rgba(0,245,255,0.3);"></i>
                        <span style="color:rgba(255,255,255,0.3); font-size:12px; letter-spacing:0.1em; text-transform:uppercase; font-weight:600;">Click play to watch</span>
                    </div>

                    <!-- Play button with pulse ring -->
                    <button class="lazy-video-play-button-tps" aria-label="Play Video">
                        <span class="play-pulse-ring"></span>
                        <i class="fa-solid fa-play relative z-10 ml-1"></i>
                    </button>

                    <!-- Bottom caption overlay -->
                    <div class="lazy-video-caption">
                        <i class="fa-solid fa-film text-secondary mr-2 text-xs"></i>
                        <span>Installation Walkthrough — 2 min</span>
                    </div>
                </div>

                <!-- Download CTA below video -->
                <a href="<%= settings['apk_file_url'] || '#' %>" class="flex items-center justify-center gap-3 py-4 px-6 bg-secondary hover:bg-cyan-300 text-[#000a14] font-black text-sm tracking-widest uppercase transition-all shadow-[0_0_20px_rgba(0,245,255,0.2)] hover:shadow-[0_0_30px_rgba(0,245,255,0.4)] relative z-10">
                    <i class="fa-solid fa-download text-base"></i> Download Now — Free
                </a>

                <style>
                    .lazy-video-wrapper-tps {
                        position: relative;
                        width: 100%;
                        display: block;
                    }
                    .lazy-video-thumbnail-tps {
                        width: 100%;
                        height: auto;
                        display: block;
                        cursor: pointer;
                    }
                    .lazy-video-caption {
                        position: absolute;
                        bottom: 0;
                        left: 0;
                        right: 0;
                        background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
                        color: rgba(255,255,255,0.7);
                        font-size: 12px;
                        padding: 20px 16px 12px;
                        display: flex;
                        align-items: center;
                        z-index: 2;
                    }
                    .lazy-video-play-button-tps {
                        position: absolute;
                        top: 50%;
                        left: 50%;
                        transform: translate(-50%, -50%);
                        z-index: 3;
                        background: rgba(0, 245, 255, 0.12);
                        color: #fff;
                        border: 2px solid rgba(0, 245, 255, 0.7);
                        border-radius: 50%;
                        width: 80px;
                        height: 80px;
                        font-size: 1.5rem;
                        cursor: pointer;
                        transition: all 0.25s ease;
                        backdrop-filter: blur(8px);
                        box-shadow: 0 0 0 0 rgba(0,245,255,0.4), 0 0 40px rgba(0,245,255,0.2);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }
                    .play-pulse-ring {
                        position: absolute;
                        inset: -6px;
                        border-radius: 50%;
                        border: 2px solid rgba(0,245,255,0.3);
                        animation: pulse-ring 2s ease-out infinite;
                    }
                    @keyframes pulse-ring {
                        0% { transform: scale(1); opacity: 0.8; }
                        100% { transform: scale(1.5); opacity: 0; }
                    }
                    .lazy-video-play-button-tps:hover {
                        background: rgba(0, 245, 255, 0.25);
                        transform: scale(1.1);
                        box-shadow: 0 0 60px rgba(0, 245, 255, 0.5);
                    }
                    .lazy-video-play-button-tps:focus { outline: none; }
                    .lazy-video-tps {
                        width: 100%;
                        height: auto;
                        display: block;
                    }
                </style>

                <script>
                    document.addEventListener("DOMContentLoaded", function () {
                        const wrapper = document.querySelector(".lazy-video-wrapper-tps");
                        const playButton = document.querySelector(".lazy-video-play-button-tps");
                        if (!playButton || !wrapper) return;

                        // Preload metadata in the background to eliminate the "delay to play"
                        const video = document.createElement("video");
                        video.className = "lazy-video-tps";
                        video.preload = "metadata"; // Fetches video headers immediately
                        video.playsInline = true;
                        video.style.cssText = "width:100%;height:auto;display:none;";
                        video.innerHTML = `<source src="/uploads/TPS-Video.mov" type="video/mp4">Your browser does not support the video tag.`;
                        wrapper.appendChild(video);

                        playButton.addEventListener("click", function () {
                            // Hide custom thumbnail, play button, and captions
                            Array.from(wrapper.children).forEach(child => {
                                if (child !== video) child.style.display = 'none';
                            });
                            
                            // Show the video player and start playing instantly
                            video.style.display = 'block';
                            video.controls = true;
                            
                            // A quick promise catch in case autoplay is blocked by browser policies
                            const playPromise = video.play();
                            if (playPromise !== undefined) {
                                playPromise.catch(error => {
                                    console.log("Auto-play prevented by browser. User must click play on the controls.");
                                });
                            }
                        });
                    });
                </script>

            </div>
        </div>
    </div>
</section>

<!-- About Us Section -->
<section id="about-us" class="relative bg-[#000a14] py-24 border-y border-secondary/10">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/diagonal-striped-brick.png')] opacity-5"></div>
    <div class="max-w-5xl mx-auto px-4 relative z-10">
