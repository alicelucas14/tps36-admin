        <p class="text-slate-400">Stay updated with the latest game tips and news.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <% featuredBlogs.forEach(blog => { %>
        <div class="relative rounded-2xl overflow-hidden group hover:-translate-y-2 transition-all duration-500 h-[380px] shadow-lg hover:shadow-[0_0_30px_rgba(250,204,21,0.3)] border border-secondary/10">
