            <% if(blog.image_url) { %>
                <img src="<%= blog.image_url %>" alt="Cover" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 z-0" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=600&auto=format&fit=crop';">
            <% } else { %>
                <div class="absolute inset-0 flex items-center justify-center text-secondary/10 z-0">
                    <i class="fa-solid fa-image text-8xl"></i>
                </div>
            <% } %>
            
            <div class="absolute inset-0 bg-gradient-to-t from-[#000a14] via-[#000a14]/80 to-transparent z-10"></div>
            
            <div class="absolute inset-0 p-6 flex flex-col justify-end z-20">
                <div class="absolute top-6 left-6">
                    <span class="bg-[#facc15] text-black text-[10px] font-black px-3 py-1.5 rounded-sm uppercase tracking-widest shadow-[0_0_10px_rgba(250,204,21,0.5)]"><%= blog.category || 'General' %></span>
                </div>
                
                <span class="text-slate-400 text-xs font-bold tracking-widest uppercase mb-2 block"><%= new Date(blog.created_at).toLocaleDateString() %></span>
                
                <h3 class="text-xl font-black mb-4 text-white group-hover:text-[#facc15] transition-colors line-clamp-2 leading-tight drop-shadow-md"><%= blog.title %></h3>
                
                <div class="mt-auto pt-4 border-t border-white/10">
                    <a href="/<%= blog.slug %>" class="inline-flex items-center gap-2 text-[#facc15] font-black uppercase tracking-widest text-sm hover:gap-4 transition-all">Read Article <i class="fa-solid fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <div class="text-center mt-12">
        <a href="/blogs" class="inline-block px-8 py-3 border-2 border-secondary text-secondary font-bold uppercase tracking-widest text-sm rounded hover:bg-secondary hover:text-primary hover:shadow-neon transition-all">View All Articles</a>
    </div>
</section>
<% } %>

<!-- Recent Reviews -->
<% if(recentReviews && recentReviews.length > 0) { %>
<section class="bg-[#000a14] py-24 border-t border-secondary/10">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-black mb-4 tracking-wider uppercase text-white">VIP Player Reviews</h2>
            <div class="w-24 h-1 bg-secondary mx-auto shadow-neon"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% recentReviews.forEach(r => { %>
            <div class="bg-accent/40 p-8 rounded-xl border border-secondary/10 relative hover:border-secondary/50 transition-colors">
                <div class="text-secondary mb-6 text-lg drop-shadow-[0_0_5px_rgba(0,245,255,0.8)]">
                    <% for(let i=0; i<r.rating; i++) { %><i class="fa-solid fa-star"></i><% } %>
                </div>
                <p class="text-slate-300 italic mb-8 leading-relaxed text-lg">"<%= r.comment.substring(0, 150) %><%= r.comment.length > 150 ? '...' : '' %>"</p>
                <div class="flex items-center gap-4 border-t border-secondary/10 pt-6">
                    <% if(r.image_url) { %>
                        <img src="<%= r.image_url %>" class="w-12 h-12 rounded-full border border-secondary p-0.5 object-cover" onerror="this.src='https://via.placeholder.com/100';">
                    <% } else { %>
                        <div class="w-12 h-12 rounded-full border border-secondary p-0.5 flex items-center justify-center bg-primary text-secondary font-bold text-xl"><%= r.reviewer_name.charAt(0).toUpperCase() %></div>
                    <% } %>
                    <span class="font-bold text-white uppercase tracking-wider"><%= r.reviewer_name %></span>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>



<!-- Include Popup Banner -->
<%- include('includes/popup') %>

<%- include('includes/footer') %>
