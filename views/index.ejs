<!-- All About Section -->
<section class="max-w-7xl mx-auto px-4 py-20 relative z-10">
    <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 rounded-full bg-white text-primary flex items-center justify-center font-black text-xl shadow-[0_0_10px_rgba(255,255,255,0.8)]"><i class="fa-solid fa-info text-base"></i></div>
        <h2 class="text-3xl md:text-4xl font-bold text-white tracking-wide">About <span class="text-[#FFF200] tracking-wide" style="text-shadow: 0 4px 6px rgba(0,0,0,0.5);">Teen Patti <span style="text-shadow: 0 4px 6px rgba(0,0,0,0.5), 0 0 20px rgba(255,242,0,0.8), 0 0 40px rgba(255,242,0,0.4);">Stars</span></span></h2>
