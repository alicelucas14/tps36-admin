<%- include('includes/header') %>

<div class="max-w-6xl mx-auto px-4 py-20 relative">

    <!-- Title -->
    <div class="text-center mb-20">
        <h1 class="text-4xl md:text-5xl font-black text-white tracking-wide mb-6">Customer Checkout Process Flow</h1>
        <p class="text-lg md:text-xl text-slate-400">The customer checkout process flow of TeenPattiStars can be shown below</p>
    </div>

    <!-- Steps Container -->
    <div class="space-y-24">

        <!-- Step 1 (Text Left, Image Right) -->
        <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
            <div class="flex-1">
                <h2 class="text-4xl font-black text-[#FFF200] mb-6 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">Step 1</h2>
                <p class="text-xl md:text-2xl leading-relaxed text-slate-300">
                    Customer needs to first Sign Up or login to the app with the help of his/her mobile number or Facebook
                </p>
            </div>
            <div class="flex-1 w-full">
                <div class="rounded-2xl border-2 border-secondary/20 overflow-hidden shadow-[0_0_30px_rgba(0,245,255,0.1)] transform hover:scale-[1.02] transition-transform duration-500">
                    <!-- Placeholder: Replace src with your actual Step 1 image -->
                    <img src="/images/hero.png" alt="Step 1 Login Screen" class="w-full h-auto object-cover">
                </div>
            </div>
        </div>

        <!-- Step 2 (Image Left, Text Right) -->
        <div class="flex flex-col md:flex-row-reverse items-center gap-12 lg:gap-20">
            <div class="flex-1">
                <h2 class="text-4xl font-black text-[#FFF200] mb-6 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">Step 2</h2>
                <p class="text-xl md:text-2xl leading-relaxed text-slate-300 mb-6">
                    After Login, customer goes to game page, where all different variety of games are available for entertainment. This game page also known as Main Game Lobby.
                </p>
                <p class="text-xl md:text-2xl leading-relaxed text-slate-300">
                    User will find all kind of rummy games on this lobby as we can see on the above picture.
                </p>
            </div>
            <div class="flex-1 w-full">
                <div class="rounded-2xl border-2 border-secondary/20 overflow-hidden shadow-[0_0_30px_rgba(0,245,255,0.1)] transform hover:scale-[1.02] transition-transform duration-500">
                    <!-- Placeholder: Replace src with your actual Step 2 image -->
                    <img src="/images/casino_phone_burst.png" alt="Step 2 Main Lobby" class="w-full h-auto object-cover bg-[#000a14]">
                </div>
            </div>
        </div>

    </div>

    <!-- Back / Contact Section -->
    <div class="mt-24 flex flex-col sm:flex-row gap-6 items-center justify-center pt-12 border-t border-secondary/20">
        <a href="/" class="flex items-center gap-2 text-slate-400 hover:text-secondary transition-colors text-base font-semibold uppercase tracking-wider">
            <i class="fa-solid fa-arrow-left"></i> Back to Home
        </a>
        <span class="text-slate-600 hidden sm:block">|</span>
        <a href="/contact" class="flex items-center gap-2 text-slate-400 hover:text-secondary transition-colors text-base font-semibold uppercase tracking-wider">
            <i class="fa-solid fa-headset"></i> Contact Support
        </a>
    </div>

</div>

<%- include('includes/footer') %>
