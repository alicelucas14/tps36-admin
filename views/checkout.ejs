<%- include('includes/header') %>

<div class="max-w-6xl mx-auto px-4 py-20 relative">

    <!-- Title -->
    <div class="text-center mb-20">
        <h1 class="text-4xl md:text-5xl font-black text-white tracking-wide mb-6">Customer Checkout Process Flow</h1>
        <p class="text-lg md:text-xl text-slate-400">The customer checkout process flow of TeenPattiStars can be shown below</p>
    </div>

    <!-- Steps Container -->
    <div class="space-y-24">
        <% if (steps && steps.length > 0) { %>
            <% steps.forEach((step, index) => { %>
                <!-- Step (Alternating Layout) -->
                <div class="flex flex-col <%= index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse' %> items-center gap-12 lg:gap-20">
                    <div class="flex-1">
                        <h2 class="text-4xl font-black text-[#FFF200] mb-6 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]"><%= step.title %></h2>
                        <div class="text-xl md:text-2xl leading-relaxed text-slate-300 whitespace-pre-wrap"><%= step.description %></div>
                    </div>
                    <div class="flex-1 w-full">
                        <div class="rounded-2xl border-2 border-cta/20 overflow-hidden shadow-[0_0_30px_rgba(250,204,21,0.1)] transform hover:scale-[1.02] transition-transform duration-500 flex flex-col gap-1 bg-cta/10">
                            <% if (step.image_url) { %>
                                <img src="<%= step.image_url %>" alt="<%= step.title %> Part 1" class="w-full h-auto object-cover bg-[#1a0008]">
                            <% } else { %>
                                <div class="w-full h-48 bg-[#1a0008] flex items-center justify-center text-slate-500">
                                    <i class="fa-solid fa-image text-4xl"></i>
                                </div>
                            <% } %>
                            <% if (step.image_url_2) { %>
                                <img src="<%= step.image_url_2 %>" alt="<%= step.title %> Part 2" class="w-full h-auto object-cover bg-[#1a0008]">
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="text-center py-12">
                <p class="text-slate-400 text-lg">No checkout steps have been configured yet.</p>
            </div>
        <% } %>
    </div>

    <!-- Back / Contact Section -->
    <div class="mt-24 flex flex-col sm:flex-row gap-6 items-center justify-center pt-12 border-t border-cta/20">
        <a href="/" class="flex items-center gap-2 text-slate-400 hover:text-cta transition-colors text-base font-semibold uppercase tracking-wider">
            <i class="fa-solid fa-arrow-left"></i> Back to Home
        </a>
        <span class="text-slate-600 hidden sm:block">|</span>
        <a href="/contact" class="flex items-center gap-2 text-slate-400 hover:text-cta transition-colors text-base font-semibold uppercase tracking-wider">
            <i class="fa-solid fa-headset"></i> Contact Support
        </a>
    </div>

</div>

<%- include('includes/footer') %>
