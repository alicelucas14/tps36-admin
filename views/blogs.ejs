<%- include('includes/header') %>

<div class="max-w-7xl mx-auto px-4 py-20 lg:py-24 relative">
    <!-- Background Glow Elements -->
    <div class="absolute top-20 right-10 w-[400px] h-[400px] bg-secondary/5 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <div class="lg:col-span-3 relative z-10">
            <div class="flex items-center justify-between mb-10 border-b border-secondary/20 pb-6">
                <h1 class="text-4xl md:text-5xl font-black tracking-wider uppercase text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.3)]">Latest <span class="text-secondary drop-shadow-[0_0_10px_rgba(0,245,255,0.5)]">News</span></h1>
                <% if(currentCategory !== 'All') { %>
                    <span class="bg-secondary/10 border border-secondary/50 text-secondary px-6 py-2 rounded-full font-bold text-sm tracking-widest uppercase shadow-neon"><%= currentCategory %></span>
                <% } %>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <% blogs.forEach(blog => { %>
                <div class="bg-accent/60 backdrop-blur-sm rounded-xl overflow-hidden border border-secondary/10 hover:border-secondary hover:-translate-y-2 hover:shadow-neon transition-all duration-300 group flex flex-col h-full">
                    <% if(blog.image_url) { %>
                        <div class="relative overflow-hidden h-56">
                            <div class="absolute inset-0 bg-primary/30 group-hover:bg-transparent transition-colors z-10"></div>
                            <img src="<%= blog.image_url %>" alt="Cover" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=600&auto=format&fit=crop';">
                        </div>
                    <% } else { %>
                        <div class="w-full h-56 bg-primary flex items-center justify-center text-slate-700 border-b border-secondary/10"><i class="fa-solid fa-image text-5xl"></i></div>
                    <% } %>
                    <div class="p-8 flex-1 flex flex-col">
                        <span class="text-xs font-bold text-secondary tracking-widest uppercase mb-4 block"><%= blog.category || 'General' %></span>
                        <h3 class="text-2xl font-bold mb-4 text-white group-hover:text-secondary transition-colors leading-tight"><%= blog.title %></h3>
                        <!-- We extract text and limit. Content is rich text, so we strip tags simply by using text overflow or just showing the first few characters. Here it renders HTML, so we should truncate cautiously. -->
                        <div class="text-slate-400 line-clamp-3 mb-6 leading-relaxed">
                            <%- blog.content.replace(/<[^>]+>/g, '') %>
                        </div>
                        <div class="mt-auto">
                            <a href="/blog/<%= blog.slug %>" class="inline-block border border-secondary text-secondary font-bold py-3 px-8 rounded hover:bg-secondary hover:text-primary transition-all tracking-widest uppercase text-sm w-full text-center">Read More</a>
                        </div>
                    </div>
                </div>
                <% }) %>
                
                <% if(blogs.length === 0) { %>
                    <div class="col-span-1 md:col-span-2 bg-accent/30 border border-dashed border-secondary/30 rounded-xl p-16 text-center">
                        <i class="fa-solid fa-ghost text-4xl text-slate-600 mb-4"></i>
                        <p class="text-slate-400 text-lg uppercase tracking-wider">No news found in this category.</p>
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="lg:col-span-1 relative z-10">
            <div class="sticky top-28 space-y-8">
                <!-- Categories Dropdown -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-secondary/20 pb-4">Categories</h3>
                    <div class="relative">
                        <select onchange="window.location.href='/blogs?category=' + encodeURIComponent(this.value)" class="w-full bg-primary border border-secondary/30 text-white font-bold tracking-wider rounded-lg p-4 focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary cursor-pointer appearance-none">
                            <option value="All" <%= currentCategory === 'All' ? 'selected' : '' %>>All Categories</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>><%= cat %></option>
                            <% }) %>
                        </select>
                        <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-secondary pointer-events-none"></i>
                    </div>
                </div>
                
                <!-- Recent Blogs -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-secondary/20 pb-4">Recent News</h3>
                    <div class="space-y-6">
                        <% recentBlogs.forEach(rb => { %>
                            <a href="/blog/<%= rb.slug %>" class="group flex items-center gap-4 hover:-translate-y-1 transition-transform">
                                <% if(rb.image_url) { %>
                                    <img src="<%= rb.image_url %>" class="w-16 h-16 object-cover rounded-lg border border-secondary/20 group-hover:border-secondary transition-colors" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=200&auto=format&fit=crop';">
                                <% } else { %>
                                    <div class="w-16 h-16 bg-primary rounded-lg border border-secondary/20 flex items-center justify-center text-secondary/50 group-hover:border-secondary transition-colors">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                <% } %>
                                <div>
                                    <h4 class="text-white font-bold text-sm leading-tight group-hover:text-secondary transition-colors line-clamp-2"><%= rb.title %></h4>
                                    <p class="text-secondary/60 text-xs font-bold tracking-wider uppercase mt-1"><%= new Date(rb.created_at).toLocaleDateString() %></p>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('includes/footer') %>
