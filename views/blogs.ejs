<%- include('includes/header') %>

<div class="max-w-7xl mx-auto px-4 py-20 lg:py-24 relative">
    <!-- Background Glow Elements -->
    <div class="absolute top-20 right-10 w-[400px] h-[400px] bg-cta/5 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <div class="lg:col-span-3 relative z-10">
            <div class="flex items-center justify-between mb-10 border-b border-cta/30 pb-6">
                <h1 class="text-4xl md:text-5xl font-black tracking-wider uppercase text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.3)]">Latest <span class="text-cta drop-shadow-[0_0_10px_rgba(250,204,21,0.5)]">News</span></h1>
                <% if(currentCategory !== 'All') { %>
                    <span class="bg-cta/10 border border-cta/50 text-cta px-6 py-2 rounded-full font-bold text-sm tracking-widest uppercase shadow-gold"><%= currentCategory %></span>
                <% } %>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                <% blogs.forEach(blog => { %>
                <div class="relative rounded-2xl overflow-hidden group hover:-translate-y-2 transition-all duration-500 h-[450px] shadow-lg hover:shadow-[0_0_30px_rgba(250,204,21,0.3)] border border-cta/20">
                    <!-- Background Image -->
                    <div class="absolute inset-0 bg-primary z-0"></div>
                    <% if(blog.image_url) { %>
                        <img src="<%= blog.image_url %>" alt="<%= blog.title %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 z-0" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=600&auto=format&fit=crop';">
                    <% } else { %>
                        <div class="absolute inset-0 flex items-center justify-center text-cta/10 z-0">
                            <i class="fa-solid fa-image text-8xl"></i>
                        </div>
                    <% } %>
                    
                    <!-- Heavy Gradient Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-[#000a14] via-[#000a14]/80 to-transparent z-10"></div>
                    
                    <!-- Content Container -->
                    <div class="absolute inset-0 p-6 flex flex-col justify-end z-20">
                        <!-- Category Badge -->
                        <div class="absolute top-6 left-6">
                            <span class="bg-[#facc15] text-black text-[10px] font-black px-3 py-1.5 rounded-sm uppercase tracking-widest shadow-[0_0_10px_rgba(250,204,21,0.5)]"><%= blog.category || 'General' %></span>
                        </div>
                        
                        <!-- Date -->
                        <span class="text-slate-400 text-xs font-bold tracking-widest uppercase mb-2 block"><%= new Date(blog.created_at).toLocaleDateString() %></span>
                        
                        <!-- Title -->
                        <h3 class="text-2xl font-black text-white leading-tight mb-3 group-hover:text-[#facc15] transition-colors line-clamp-2 drop-shadow-md"><%= blog.title %></h3>
                        
                        <!-- Snippet -->
                        <div class="text-slate-300 text-sm line-clamp-2 mb-6 font-medium leading-relaxed opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                            <%- blog.content.replace(/<[^>]+>/g, '') %>
                        </div>
                        
                        <!-- Button -->
                        <div class="mt-auto pt-4 border-t border-white/10">
                            <a href="/<%= blog.slug %>" class="inline-flex items-center gap-2 text-[#facc15] font-black uppercase tracking-widest text-sm hover:gap-4 transition-all">Read Article <i class="fa-solid fa-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
                <% }) %>
                
                <% if(blogs.length === 0) { %>
                    <div class="col-span-1 md:col-span-2 bg-accent/30 border border-dashed border-cta/30 rounded-xl p-16 text-center">
                        <i class="fa-solid fa-ghost text-4xl text-slate-600 mb-4"></i>
                        <p class="text-slate-400 text-lg uppercase tracking-wider">No news found in this category.</p>
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="lg:col-span-1 relative z-10">
            <div class="sticky top-28 space-y-8">
                <!-- Categories Dropdown -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-cta/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)] relative z-20">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-cta/20 pb-4">Categories</h3>
                    <div class="relative" id="custom-category-select">
                        <button type="button" onclick="document.getElementById('cat-dropdown').classList.toggle('hidden')" class="w-full bg-primary border border-cta/30 text-white font-bold tracking-wider rounded-lg p-4 focus:outline-none focus:border-cta focus:ring-1 focus:ring-cta cursor-pointer flex justify-between items-center text-left transition-all">
                            <span><%= currentCategory === 'All' || !currentCategory ? 'All Categories' : currentCategory %></span>
                            <i class="fa-solid fa-chevron-down text-cta transition-transform" id="cat-icon"></i>
                        </button>
                        
                        <div id="cat-dropdown" class="hidden absolute top-full left-0 w-full mt-2 bg-primary border border-cta/30 rounded-lg shadow-gold z-50 overflow-hidden">
                            <a href="/blogs?category=All" class="block px-4 py-3 text-white font-bold hover:bg-cta hover:text-[#1a0008] transition-colors <%= currentCategory === 'All' ? 'bg-cta/10 text-cta' : '' %>">All Categories</a>
                            <% categories.forEach(cat => { %>
                                <a href="/blogs?category=<%= encodeURIComponent(cat) %>" class="block px-4 py-3 text-white font-bold hover:bg-cta hover:text-[#1a0008] transition-colors <%= currentCategory === cat ? 'bg-cta/10 text-cta' : '' %>"><%= cat %></a>
                            <% }) %>
                        </div>
                    </div>

                    <script>
                        // Close dropdown when clicking outside
                        document.addEventListener('click', function(e) {
                            const select = document.getElementById('custom-category-select');
                            const dropdown = document.getElementById('cat-dropdown');
                            if (select && dropdown && !select.contains(e.target)) {
                                dropdown.classList.add('hidden');
                            }
                        });
                    </script>
                </div>
                
                <!-- Recent Blogs -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-cta/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-cta/20 pb-4">Recent News</h3>
                    <div class="space-y-6">
                        <% recentBlogs.forEach(rb => { %>
                            <a href="/<%= rb.slug %>" class="group flex items-center gap-4 hover:-translate-y-1 transition-transform">
                                <% if(rb.image_url) { %>
                                    <img src="<%= rb.image_url %>" alt="<%= rb.title %>" class="w-16 h-16 object-cover rounded-lg border border-cta/20 group-hover:border-cta transition-colors" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=200&auto=format&fit=crop';">
                                <% } else { %>
                                    <div class="w-16 h-16 bg-primary rounded-lg border border-cta/20 flex items-center justify-center text-cta/50 group-hover:border-cta transition-colors">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                <% } %>
                                <div>
                                    <h4 class="text-white font-bold text-sm leading-tight group-hover:text-cta transition-colors line-clamp-2"><%= rb.title %></h4>
                                    <p class="text-cta/60 text-xs font-bold tracking-wider uppercase mt-1"><%= new Date(rb.created_at).toLocaleDateString() %></p>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('includes/footer') %>
