<%- include('includes/header') %>

<div class="max-w-7xl mx-auto px-4 py-20 lg:py-24 relative">
    <!-- Background Glow Elements -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[300px] bg-secondary/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <div class="lg:col-span-3 relative z-10">
            
            <article class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 overflow-hidden shadow-[0_0_40px_rgba(0,0,0,0.6)]">
                <% if(blog.image_url) { %>
                    <div class="w-full h-[300px] md:h-[450px] relative">
                        <div class="absolute inset-0 bg-gradient-to-t from-accent/90 to-transparent z-10"></div>
                        <img src="<%= blog.image_url %>" alt="<%= blog.title %>" class="w-full h-full object-cover" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=1200&auto=format&fit=crop';">
                        
                        <div class="absolute bottom-8 left-8 right-8 z-20">
                            <span class="bg-secondary/20 border border-secondary text-secondary px-4 py-1 rounded-full font-bold text-xs tracking-widest uppercase shadow-neon mb-4 inline-block"><%= blog.category || 'General' %></span>
                            <h1 class="text-3xl md:text-5xl font-black text-white leading-tight drop-shadow-[0_0_10px_rgba(0,0,0,0.8)]"><%= blog.title %></h1>
                            <div class="mt-4 text-slate-400 font-medium tracking-wide text-sm flex items-center gap-4">
                                <span><i class="fa-regular fa-calendar-days text-secondary"></i> <%= new Date(blog.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                                <span><i class="fa-solid fa-eye text-secondary"></i> <%= blog.views || 0 %> Views</span>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="p-8 md:p-12 border-b border-secondary/20 bg-primary">
                        <span class="bg-secondary/20 border border-secondary text-secondary px-4 py-1 rounded-full font-bold text-xs tracking-widest uppercase shadow-neon mb-4 inline-block"><%= blog.category || 'General' %></span>
                        <h1 class="text-3xl md:text-5xl font-black text-white leading-tight drop-shadow-[0_0_5px_rgba(255,255,255,0.2)]"><%= blog.title %></h1>
                        <div class="mt-4 text-slate-400 font-medium tracking-wide text-sm flex items-center gap-4">
                            <span><i class="fa-regular fa-calendar-days text-secondary"></i> <%= new Date(blog.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                            <span><i class="fa-solid fa-eye text-secondary"></i> <%= blog.views || 0 %> Views</span>
                        </div>
                    </div>
                <% } %>
                
                <div class="p-8 md:p-12">
                    <div class="prose prose-invert prose-lg max-w-none text-slate-300 leading-relaxed font-medium 
                                prose-headings:text-white prose-headings:font-black prose-headings:tracking-wide
                                prose-a:text-secondary prose-a:font-bold prose-a:no-underline hover:prose-a:underline hover:prose-a:text-white hover:prose-a:drop-shadow-[0_0_5px_rgba(0,245,255,0.8)] transition-all
                                prose-strong:text-white prose-strong:font-bold">
                        <%- blog.content %>
                    </div>
                    
                    <% if(blog.external_link && blog.link_text) { %>
                        <div class="mt-12 pt-8 border-t border-secondary/20 text-center">
                            <a href="<%= blog.external_link %>" target="_blank" class="inline-block bg-secondary text-primary font-black py-4 px-10 rounded shadow-neon tracking-widest uppercase hover:bg-white transition-all transform hover:scale-105"><%= blog.link_text %></a>
                        </div>
                    <% } else if(blog.external_link) { %>
                        <div class="mt-12 pt-8 border-t border-secondary/20 text-center">
                            <a href="<%= blog.external_link %>" target="_blank" class="inline-block bg-secondary text-primary font-black py-4 px-10 rounded shadow-neon tracking-widest uppercase hover:bg-white transition-all transform hover:scale-105">Play Now</a>
                        </div>
                    <% } %>
                </div>
            </article>
            
            <div class="mt-8 flex items-center justify-between">
                <a href="/blogs" class="flex items-center gap-2 text-slate-400 hover:text-secondary font-bold tracking-widest uppercase text-sm transition-all"><i class="fa-solid fa-arrow-left"></i> Back to News</a>
            </div>
        </div>
        
        <div class="lg:col-span-1 relative z-10">
            <div class="sticky top-28 space-y-8">
                <!-- Table of Contents -->
                <div id="toc-widget" class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)] hidden">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-secondary/20 pb-4">Table of Contents</h3>
                    <ul id="toc-list" class="space-y-3">
                        <!-- Populated by JS -->
                    </ul>
                </div>
                
                <!-- Categories Dropdown -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-secondary/20 pb-4">Categories</h3>
                    <div class="relative">
                        <select onchange="window.location.href='/blogs?category=' + encodeURIComponent(this.value)" class="w-full bg-primary border border-secondary/30 text-white font-bold tracking-wider rounded-lg p-4 focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary cursor-pointer appearance-none">
                            <option value="All" <%= currentCategory === 'All' ? 'selected' : '' %>>All Categories</option>
                            <% categories.forEach(cat => { %>
                                <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>><%= cat %></option>
                            <% }) %>
                        </select>
                        <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-secondary pointer-events-none"></i>
                    </div>
                </div>
                
                <!-- Recent Blogs -->
                <div class="bg-accent/80 backdrop-blur-md rounded-2xl border border-secondary/20 p-8 shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                    <h3 class="text-xl font-black mb-6 tracking-widest uppercase text-white border-b border-secondary/20 pb-4">Recent News</h3>
                    <div class="space-y-6">
                        <% recentBlogs.forEach(rb => { %>
                            <a href="/<%= rb.slug %>" class="group block bg-primary/30 rounded-xl overflow-hidden border border-secondary/10 hover:border-secondary hover:-translate-y-1 transition-all">
                                <% if(rb.image_url) { %>
                                    <div class="h-32 w-full overflow-hidden relative">
                                        <div class="absolute inset-0 bg-gradient-to-t from-primary to-transparent z-10 opacity-60"></div>
                                        <img src="<%= rb.image_url %>" alt="<%= rb.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1518133910546-b6c2fb7d79e3?q=80&w=400&auto=format&fit=crop';">
                                    </div>
                                <% } else { %>
                                    <div class="h-32 w-full bg-primary flex items-center justify-center text-secondary/30 group-hover:text-secondary/60 transition-colors">
                                        <i class="fa-solid fa-image text-3xl"></i>
                                    </div>
                                <% } %>
                                <div class="p-4">
                                    <h4 class="text-white font-bold text-sm leading-snug group-hover:text-secondary transition-colors line-clamp-2"><%= rb.title %></h4>
                                    <div class="flex items-center justify-between mt-3">
                                        <p class="text-secondary/60 text-xs font-bold tracking-wider uppercase"><%= new Date(rb.created_at).toLocaleDateString() %></p>
                                        <p class="text-secondary/60 text-xs font-bold tracking-wider flex items-center gap-1"><i class="fa-solid fa-eye"></i> <%= rb.views || 0 %></p>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const contentDiv = document.querySelector('.prose');
        const tocWidget = document.getElementById('toc-widget');
        const tocList = document.getElementById('toc-list');
        
        if (!contentDiv) return;
        
        const headings = contentDiv.querySelectorAll('h1, h2, h3');
        if (headings.length === 0) return;
        
        // Show widget since we have headings
        tocWidget.classList.remove('hidden');
        
        headings.forEach((heading, index) => {
            // Ensure heading has an ID
            if (!heading.id) {
                heading.id = 'heading-' + index;
            }
            
            const li = document.createElement('li');
            
            // Indentation
            if (heading.tagName === 'H2') li.classList.add('ml-4');
            if (heading.tagName === 'H3') li.classList.add('ml-8');
            
            const a = document.createElement('a');
            a.href = '#' + heading.id;
            a.textContent = heading.textContent;
            a.className = 'text-slate-300 hover:text-secondary transition-colors text-sm font-bold flex items-center gap-2';
            
            // Add a subtle bullet indicator
            if (heading.tagName === 'H1') {
                a.innerHTML = `<i class="fa-solid fa-angle-right text-secondary text-xs"></i> ${heading.textContent}`;
            } else {
                a.innerHTML = `<span class="w-1.5 h-1.5 bg-secondary/50 rounded-full inline-block"></span> ${heading.textContent}`;
            }
            
            li.appendChild(a);
            tocList.appendChild(li);
        });
        
        // Smooth scrolling
        tocList.querySelectorAll('a').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1);
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    const headerOffset = 120; // Adjust for sticky header
                    const elementPosition = targetElement.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                    
                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            });
        });
    });
</script>

<%- include('includes/footer') %>
