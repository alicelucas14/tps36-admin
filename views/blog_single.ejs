<%- include('includes/header') %>

<div class="bg-[#ea650d] py-12 md:py-20 px-4 min-h-screen">
    <div class="max-w-7xl mx-auto bg-[#fcf9f2] rounded-[2rem] p-8 md:p-12 lg:p-16 shadow-2xl">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
            
            <!-- Left Column -->
            <div class="lg:col-span-8">
                <!-- Back Link -->
                <a href="/blogs" class="text-orange-700 font-bold text-sm hover:text-orange-900 transition-colors mb-8 inline-block">
                    Back to All Posts
                </a>
                
                <!-- Title -->
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#1b2f5b] font-black leading-tight mb-8">
                    <%= blog.title %>
                </h1>
                
                <!-- Rich Text Content -->
                <div class="prose prose-lg max-w-none text-gray-700 mb-16 leading-relaxed
                            prose-headings:text-[#1b2f5b] prose-headings:font-serif
                            prose-a:text-orange-600 hover:prose-a:text-orange-800
                            prose-strong:text-gray-900 prose-img:rounded-xl">
                    <%- blog.content %>
                </div>
                
                <% if(blog.external_link) { %>
                    <div class="mb-16">
                        <a href="<%= blog.external_link %>" target="_blank" class="inline-block bg-orange-600 text-white font-bold py-4 px-10 rounded-full hover:bg-orange-700 transition-colors shadow-lg"><%= blog.link_text || 'Play Now' %></a>
                    </div>
                <% } %>
                
                <!-- Divider -->
                <hr class="border-gray-300 mb-10">
                
                <!-- Related Posts (Cards) -->
                <h3 class="text-xl md:text-2xl font-serif text-[#1b2f5b] font-bold mb-8">Related Posts</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <% recentBlogs.slice(0, 2).forEach(rb => { %>
                        <a href="/<%= rb.slug %>" class="group block border border-orange-400 rounded-3xl overflow-hidden hover:shadow-xl transition-all duration-300 bg-[#fcf8f2]">
                            <div class="h-48 w-full bg-[#f4eadd] overflow-hidden flex items-center justify-center relative">
                                <% if(rb.image_url) { %>
                                    <img src="<%= rb.image_url %>" alt="<%= rb.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                <% } else { %>
                                    <i class="fa-solid fa-image text-5xl text-orange-200"></i>
                                <% } %>
                            </div>
                            <div class="p-8 bg-white">
                                <span class="border border-orange-200 text-[#ea650d] text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest"><%= rb.category || 'General' %></span>
                                <h4 class="text-[#1b2f5b] font-serif font-black text-xl md:text-2xl mt-4 line-clamp-3 leading-snug group-hover:text-orange-600 transition-colors"><%= rb.title %></h4>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
            
            <!-- Right Column -->
            <div class="lg:col-span-4">
                <div class="sticky top-24">
                    <!-- Main Image -->
                    <div class="bg-[#fcf9f2] border border-gray-200 rounded-3xl p-4 shadow-sm mb-12">
                        <% if(blog.image_url) { %>
                            <img src="<%= blog.image_url %>" alt="<%= blog.title %>" class="w-full aspect-square object-cover rounded-2xl">
                        <% } else { %>
                            <div class="w-full aspect-square bg-[#f4eadd] rounded-2xl flex items-center justify-center">
                                <i class="fa-solid fa-image text-6xl text-orange-200"></i>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Meta Data -->
                    <div class="grid grid-cols-3 gap-y-6 text-sm mb-12">
                        <div class="font-bold text-[#1b2f5b]">Author</div>
                        <div class="col-span-2 text-gray-600">Product Team</div>
                        
                        <div class="font-bold text-[#1b2f5b]">Category</div>
                        <div class="col-span-2 text-gray-600"><%= blog.category || 'Product' %></div>
                        
                        <div class="font-bold text-[#1b2f5b]">Published</div>
                        <div class="col-span-2 text-gray-600"><%= new Date(blog.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                    </div>
                    
                    <!-- Recent Posts List -->
                    <h3 class="text-xl md:text-2xl font-serif text-[#1b2f5b] font-bold mb-6">Recent Posts</h3>
                    <div class="space-y-4">
                        <% recentBlogs.forEach(rb => { %>
                            <a href="/<%= rb.slug %>" class="block bg-white border border-gray-200 p-5 rounded-2xl hover:border-orange-400 hover:shadow-md transition-all group">
                                <h4 class="text-[#1b2f5b] font-bold text-sm leading-snug group-hover:text-orange-600 transition-colors line-clamp-2"><%= rb.title %></h4>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<%- include('includes/footer') %>
