<%- include('includes/header') %>

<div class="max-w-4xl mx-auto px-4 py-20 lg:py-24 relative">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-secondary/5 blur-[150px] rounded-full pointer-events-none"></div>

    <div class="text-center mb-16 relative z-10">
        <h1 class="text-4xl md:text-5xl font-black mb-4 tracking-wider uppercase text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.3)]">Frequently Asked <span class="text-secondary drop-shadow-[0_0_10px_rgba(0,245,255,0.5)]">Questions</span></h1>
        <div class="w-24 h-1 bg-secondary mx-auto shadow-neon"></div>
    </div>
    
    <div class="space-y-4 relative z-10">
        <% faqs.forEach(f => { %>
        <details class="group bg-accent/60 backdrop-blur-sm rounded-xl border border-secondary/10 open:border-secondary/40 hover:border-secondary/30 transition-all duration-300">
            <summary class="flex justify-between items-center font-bold tracking-wide cursor-pointer list-none p-6 md:p-8 text-white group-hover:text-secondary transition-colors text-lg">
                <span><%= f.question %></span>
                <span class="transition-transform group-open:rotate-180 text-secondary bg-secondary/10 w-10 h-10 rounded-full flex items-center justify-center shrink-0 ml-4 border border-secondary/20 group-hover:border-secondary shadow-[0_0_10px_rgba(0,245,255,0.2)]">
                    <i class="fa-solid fa-chevron-down text-sm"></i>
                </span>
            </summary>
            <div class="text-slate-300 p-6 md:p-8 pt-0 leading-relaxed border-t border-secondary/10">
                <% if(f.image_url) { %>
                    <img src="<%= f.image_url %>" alt="FAQ Image" class="w-full md:w-1/2 rounded-lg object-cover mb-6 border border-secondary/20 shadow-[0_0_15px_rgba(0,0,0,0.5)]" onerror="this.onerror=null; this.src='https://via.placeholder.com/600x400/001c3d/00f5ff?text=Information';">
                <% } %>
                <div class="prose prose-invert prose-p:text-slate-300 max-w-none">
                    <%= f.answer %>
                </div>
            </div>
        </details>
        <% }) %>
        
        <% if(faqs.length === 0) { %>
            <div class="bg-accent/30 border border-dashed border-secondary/30 rounded-xl p-16 text-center">
                <i class="fa-solid fa-circle-question text-4xl text-slate-600 mb-4"></i>
                <p class="text-slate-400 text-lg uppercase tracking-wider">No FAQs added yet.</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('includes/footer') %>
