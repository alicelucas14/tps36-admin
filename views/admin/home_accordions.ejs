<%- include('includes/header') %>

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-800">Home Accordions</h1>
        <p class="text-gray-500 mt-1">Manage the "All About" section on the homepage.</p>
    </div>
</div>

<!-- Image Management Section -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-solid fa-image text-blue-500 mr-2"></i> Section Image</h3>
    <form action="/admin/settings" method="POST" enctype="multipart/form-data" class="flex gap-4 items-end">
        <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Upload Image</label>
            <input type="file" name="home_accordion_image" accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            <!-- Hidden fallback -->
            <input type="hidden" name="existing_home_accordion_image" value="<%= settings['home_accordion_image'] || '' %>">
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition whitespace-nowrap">Upload Image</button>
    </form>
    <% if(settings['home_accordion_image']) { %>
        <div class="mt-4 p-4 bg-gray-50 rounded border border-gray-200 inline-block">
            <p class="text-xs text-gray-500 mb-2 font-bold uppercase">Current Preview:</p>
            <img src="<%= settings['home_accordion_image'] %>" class="h-32 object-contain bg-gray-900 rounded" alt="Preview">
        </div>
    <% } %>
</div>

<!-- Add New Accordion -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8 border-l-4 border-l-green-500">
    <h3 class="text-lg font-bold text-gray-800 mb-4"><i class="fa-solid fa-plus-circle text-green-500 mr-2"></i> Add New Accordion</h3>
    <form action="/admin/home-accordions" method="POST" class="space-y-4">
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Question</label>
            <input type="text" name="question" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 outline-none" placeholder="e.g. What makes us different?">
        </div>
        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Answer</label>
            <textarea name="answer" required rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 outline-none resize-none" placeholder="e.g. We offer the best gaming experience..."></textarea>
        </div>
        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-medium transition">Add Accordion</button>
    </form>
</div>

<!-- Existing Accordions -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-solid fa-list text-gray-500 mr-2"></i> Existing Accordions</h3>
    
    <% if(accordions && accordions.length > 0) { %>
        <div class="space-y-4">
            <% accordions.forEach(item => { %>
                <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition bg-gray-50">
                    <div class="flex justify-between items-start gap-4">
                        <div class="flex-1">
                            <h4 class="font-bold text-lg text-gray-800 mb-1"><%= item.question %></h4>
                            <p class="text-gray-600 text-sm"><%= item.answer %></p>
                            <span class="text-xs text-gray-400 mt-2 block">Added: <%= new Date(item.created_at).toLocaleDateString() %></span>
                        </div>
                        <div class="flex items-center gap-2">
                            <a href="/admin/home-accordions/edit/<%= item.id %>" class="text-blue-500 hover:text-blue-700 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded transition text-sm font-bold">
                                <i class="fa-solid fa-pen"></i> Edit
                            </a>
                            <form action="/admin/home-accordions/delete/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this accordion permanently?');">
                                <button type="submit" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded transition text-sm font-bold">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-8 bg-gray-50 rounded-lg border border-dashed border-gray-300">
            <i class="fa-solid fa-folder-open text-3xl text-gray-400 mb-2 block"></i>
            <p class="text-gray-500">No home accordions found. Add your first one above!</p>
        </div>
    <% } %>
</div>

<%- include('includes/footer') %>
