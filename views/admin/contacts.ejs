<%- include('includes/header') %>

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
    <h1 class="text-3xl font-bold text-gray-800">Contact Messages</h1>
    
    <!-- Filter and Export Actions -->
    <div class="flex flex-col lg:flex-row gap-3 w-full md:w-auto">
        <form action="/admin/contacts" method="GET" class="flex flex-col sm:flex-row items-center gap-3 bg-white p-2 rounded-lg shadow-sm border border-gray-200">
            <div class="flex items-center gap-2">
                <label for="start_date" class="text-sm font-semibold text-gray-600">From:</label>
                <input type="date" name="start_date" id="start_date" value="<%= typeof start_date !== 'undefined' ? start_date : '' %>" class="px-2 py-1 text-sm border border-gray-300 rounded focus:outline-none focus:border-blue-500 text-gray-700">
            </div>
            <div class="flex items-center gap-2">
                <label for="end_date" class="text-sm font-semibold text-gray-600">To:</label>
                <input type="date" name="end_date" id="end_date" value="<%= typeof end_date !== 'undefined' ? end_date : '' %>" class="px-2 py-1 text-sm border border-gray-300 rounded focus:outline-none focus:border-blue-500 text-gray-700">
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded text-sm font-semibold transition-colors flex items-center gap-2">
                <i class="fa-solid fa-filter"></i> Filter
            </button>
            <% if ((typeof start_date !== 'undefined' && start_date) || (typeof end_date !== 'undefined' && end_date)) { %>
                <a href="/admin/contacts" class="text-gray-500 hover:text-red-500 text-sm transition-colors px-2" title="Clear Filters"><i class="fa-solid fa-xmark"></i></a>
            <% } %>
        </form>
        
        <form action="/admin/contacts/export" method="GET" class="flex">
            <input type="hidden" name="start_date" value="<%= typeof start_date !== 'undefined' ? start_date : '' %>">
            <input type="hidden" name="end_date" value="<%= typeof end_date !== 'undefined' ? end_date : '' %>">
            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg text-sm font-bold shadow-sm transition-transform hover:scale-105 flex items-center gap-2 w-full justify-center">
                <i class="fa-solid fa-file-excel"></i> Export CSV
            </button>
        </form>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">From</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Message</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Date</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            <% contacts.forEach(msg => { %>
            <tr>
                <td class="px-6 py-4">
                    <div class="font-bold text-gray-900"><%= msg.first_name %> <%= msg.last_name %></div>
                    <div class="text-xs text-blue-500 lowercase"><%= msg.email %></div>
                </td>
                <td class="px-6 py-4">
                    <div class="text-sm text-gray-700 max-w-md break-words"><%= msg.message %></div>
                </td>
                <td class="px-6 py-4 text-xs text-gray-400">
                    <%= new Date(msg.created_at).toLocaleString() %>
                </td>
                <td class="px-6 py-4 text-right">
                    <form method="POST" action="/admin/contacts/delete/<%= msg.id %>" onsubmit="return confirm('Are you sure you want to delete this message?');" class="inline">
                        <button type="submit" class="text-red-500 hover:text-red-700 transition">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </form>
                </td>
            </tr>
            <% }) %>
            <% if(contacts.length === 0) { %>
                <tr>
                    <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">No contact entries yet.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('includes/footer') %>
