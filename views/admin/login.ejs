<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - Node CMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <div class="p-8 text-center border-b border-gray-100">
            <img src="/images/Teen-Patti-Stars-Logo.webp" alt="Teen Patti Stars" class="h-20 w-auto mx-auto mb-4 drop-shadow-md">
            <h2 class="text-2xl font-bold text-gray-900">Admin Secure Login</h2>
            <p class="text-gray-500 mt-1">Teen Patti Stars Content Management System</p>
        </div>
        
        <div class="p-8">
            <% if (error) { %>
                <div class="bg-red-50 text-red-600 text-sm p-3 rounded-lg border border-red-100 mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
                </div>
            <% } %>

            <form method="POST" action="/admin/login" class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Username</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <input type="text" name="username" required 
                               class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-gray-700" 
                               placeholder="Enter username (admin)">
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </div>
                        <input type="password" name="password" required 
                               class="w-full pl-10 pr-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none text-gray-700" 
                               placeholder="Enter password (password)">
                    </div>
                </div>
                
                <button type="submit" class="w-full bg-gray-900 hover:bg-black text-white font-bold py-3 px-4 rounded-lg transition-colors mt-8 shadow-md">
                    Access Dashboard <i class="fa-solid fa-arrow-right ml-2 opacity-50"></i>
                </button>
            </form>
        </div>
        
        <div class="text-center py-4 bg-gray-50 border-t border-gray-100 space-y-2">
            <p class="text-xs text-gray-400 font-medium tracking-wide">AUTHORIZED PERSONNEL ONLY</p>
            <a href="/admin/register" class="text-xs text-blue-500 hover:text-blue-700 font-semibold transition">
                <i class="fa-solid fa-user-plus mr-1"></i> Create New Account
            </a>
        </div>
    </div>

</body>
</html>
