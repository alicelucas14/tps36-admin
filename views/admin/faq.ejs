<%- include('includes/header') %>

<div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Manage FAQs</h1>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <h3 class="text-lg font-bold mb-4"><%= typeof editItem !== 'undefined' && editItem ? 'Edit FAQ' : 'Add FAQ' %></h3>
    <form method="POST" action="/admin/faq" enctype="multipart/form-data" class="space-y-4">
        <% if(typeof editItem !== 'undefined' && editItem) { %>
            <input type="hidden" name="action" value="edit">
            <input type="hidden" name="id" value="<%= editItem.id %>">
            <input type="hidden" name="existing_image" value="<%= editItem.image_url %>">
        <% } %>
        <div>
            <label class="block text-sm font-medium mb-1">Question</label>
            <input type="text" name="question" value="<%= typeof editItem !== 'undefined' && editItem ? editItem.question : '' %>" required class="w-full border rounded px-3 py-2">
        </div>
        <div>
            <label class="block text-sm font-medium mb-1">Upload Image (Optional) <% if(typeof editItem !== 'undefined' && editItem && editItem.image_url) { %><span class="text-xs text-blue-500 font-normal ml-2">(Current: <%= editItem.image_url %>)</span><% } %></label>
            <input type="file" name="image" accept="image/*" class="w-full border rounded px-3 py-1 bg-gray-50 focus:outline-none">
        </div>
        <div>
            <label class="block text-sm font-medium mb-1">Answer</label>
            <textarea name="answer" required rows="3" class="w-full border rounded px-3 py-2"><%= typeof editItem !== 'undefined' && editItem ? editItem.answer : '' %></textarea>
        </div>
        <div class="flex items-center gap-4">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-medium"><%= typeof editItem !== 'undefined' && editItem ? 'Update FAQ' : 'Save FAQ' %></button>
            <% if(typeof editItem !== 'undefined' && editItem) { %>
                <a href="/admin/faq" class="text-gray-500 hover:text-gray-700 font-medium">Cancel Edit</a>
            <% } %>
        </div>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Question</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            <% faqs.forEach(f => { %>
            <tr>
                <td class="px-6 py-4 font-medium"><%= f.question %></td>
                <td class="px-6 py-4 text-right">
                    <a href="/admin/faq?edit_id=<%= f.id %>" class="text-blue-500 hover:text-blue-700 mr-3"><i class="fa-solid fa-pen"></i></a>
                    <form method="POST" action="/admin/faq" class="inline">
                        <input type="hidden" name="action" value="delete">
                        <input type="hidden" name="id" value="<%= f.id %>">
                        <button type="submit" class="text-red-500 hover:text-red-700"><i class="fa-solid fa-trash"></i></button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('includes/footer') %>
