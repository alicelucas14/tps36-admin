<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Create Admin Account — Teen Patti Stars</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .input-field { width:100%; background:#f1f5f9; border:2px solid transparent; border-radius:12px; padding:12px 16px 12px 44px; font-size:14px; transition:all .2s; outline:none; }
        .input-field:focus { background:#fff; border-color:#3b82f6; box-shadow:0 0 0 4px rgba(59,130,246,0.1); }
        .input-wrap { position:relative; }
        .input-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:14px; }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 to-blue-50 flex items-center justify-center p-4">

<div class="w-full max-w-md">
    <div class="bg-white rounded-3xl shadow-2xl p-8 border border-gray-100">

        <!-- Logo -->
        <div class="text-center mb-8">
            <img src="/images/Teen-Patti-Stars-Logo.webp" alt="Teen Patti Stars" class="h-16 mx-auto mb-4" onerror="this.style.display='none'">
            <h1 class="text-2xl font-black text-gray-900">Create Admin Account</h1>
            <p class="text-gray-400 text-sm mt-1">You'll need a registration key from your administrator</p>
        </div>

        <!-- Success -->
        <% if (success) { %>
        <div class="mb-6 flex flex-col items-center gap-3 bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-5 text-sm text-center">
            <i class="fa-solid fa-circle-check text-3xl text-green-500"></i>
            <div>
                <div class="font-bold text-base"><%= success %></div>
                <a href="/admin/login" class="mt-2 inline-block text-blue-600 font-semibold hover:underline">Go to Login →</a>
            </div>
        </div>
        <% } %>

        <!-- Error -->
        <% if (error) { %>
        <div class="mb-5 flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm font-semibold">
            <i class="fa-solid fa-circle-exclamation text-red-500"></i> <%= error %>
        </div>
        <% } %>

        <% if (!success) { %>
        <form method="POST" action="/admin/register" class="space-y-4">

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Username</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-user input-icon"></i>
                    <input type="text" name="username" required placeholder="Choose a username"
                        class="input-field" autocomplete="off">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock input-icon"></i>
                    <input type="password" name="password" required placeholder="Min 6 characters"
                        class="input-field">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Confirm Password</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock input-icon"></i>
                    <input type="password" name="confirm_password" required placeholder="Repeat your password"
                        class="input-field">
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Registration Key</label>
                <div class="input-wrap">
                    <i class="fa-solid fa-key input-icon"></i>
                    <input type="text" name="registration_key" required placeholder="Enter the key provided by admin"
                        class="input-field" autocomplete="off">
                </div>
                <p class="text-xs text-gray-400 mt-1.5">Ask your administrator for the registration key</p>
            </div>

            <button type="submit"
                class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl text-sm tracking-wide transition-all shadow-lg hover:shadow-blue-200 hover:-translate-y-0.5 flex items-center justify-center gap-2 mt-6">
                <i class="fa-solid fa-user-plus"></i> Create Account
            </button>
        </form>
        <% } %>

        <div class="text-center mt-6">
            <a href="/admin/login" class="text-sm text-gray-400 hover:text-blue-600 transition font-medium flex items-center justify-center gap-1">
                <i class="fa-solid fa-arrow-left text-xs"></i> Back to Login
            </a>
        </div>

    </div>
    <p class="text-center text-xs text-gray-400 mt-4 uppercase tracking-widest">Authorized Personnel Only</p>
</div>

</body>
</html>
