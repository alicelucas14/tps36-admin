<%- include('includes/header') %>

<div class="flex items-center gap-4 mb-8">
    <a href="/admin/checkout-steps" class="text-gray-400 hover:text-blue-600 transition">
        <i class="fa-solid fa-arrow-left text-xl"></i>
    </a>
    <div>
        <h1 class="text-3xl font-bold text-gray-800">Edit Checkout Step</h1>
        <p class="text-gray-500 mt-1">Update details for <%= step.title %></p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 border-l-4 border-l-blue-500 max-w-4xl">
    <form action="/admin/checkout-steps/edit/<%= step.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
        <input type="hidden" name="existing_image" value="<%= step.image_url %>">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Step Number</label>
                <input type="number" name="step_number" value="<%= step.step_number %>" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Step Title</label>
                <input type="text" name="title" value="<%= step.title %>" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                <textarea name="description" rows="4" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"><%= step.description %></textarea>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Change Image (Optional)</label>
                <% if(step.image_url) { %>
                    <div class="mb-3">
                        <img src="<%= step.image_url %>" alt="Current Image" class="w-48 h-auto rounded border border-gray-200">
                    </div>
                <% } %>
                <input type="file" name="image" accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                <p class="text-xs text-gray-500 mt-1">Leave empty to keep the current image.</p>
            </div>
        </div>
        
        <div class="flex items-center gap-3 mt-8 pt-6 border-t border-gray-100">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition">Save Changes</button>
            <a href="/admin/checkout-steps" class="px-6 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100 transition">Cancel</a>
        </div>
    </form>
</div>

<%- include('includes/footer') %>
