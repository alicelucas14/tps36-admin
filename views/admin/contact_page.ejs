<%- include('includes/header') %>

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-800">Contact Page Panel</h1>
        <p class="text-gray-500 mt-1">Manage the contact cards and FAQ image on the Contact page.</p>
    </div>
</div>

<!-- FAQ Image Management -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-solid fa-image text-purple-500 mr-2"></i> FAQ Section Image</h3>
    <form action="/admin/settings" method="POST" class="flex gap-4 items-end">
        <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Image URL (Appears next to FAQs)</label>
            <input type="text" name="contact_faq_image" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 outline-none" value="<%= settings['contact_faq_image'] || '' %>">
        </div>
        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-lg font-medium transition whitespace-nowrap">Save Image</button>
    </form>
    <% if(settings['contact_faq_image']) { %>
        <div class="mt-4 p-4 bg-gray-50 rounded border border-gray-200 inline-block">
            <p class="text-xs text-gray-500 mb-2 font-bold uppercase">Current Preview:</p>
            <img src="<%= settings['contact_faq_image'] %>" class="h-32 object-contain bg-gray-900 rounded" alt="Preview">
        </div>
    <% } %>
</div>

<!-- Add New Contact Card -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8 border-l-4 border-l-blue-500">
    <h3 class="text-lg font-bold text-gray-800 mb-4"><i class="fa-solid fa-plus-circle text-blue-500 mr-2"></i> Add New Contact Card</h3>
    <form action="/admin/contact-page/card" method="POST" enctype="multipart/form-data" class="space-y-4">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Subtitle (e.g. Instant Help)</label>
                <input type="text" name="subtitle" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Title (e.g. Live Chat) *</label>
                <input type="text" name="title" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
            <textarea name="description" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none resize-none"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Button Text (e.g. Chat Now)</label>
                <input type="text" name="button_text" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Button Link</label>
                <input type="text" name="button_link" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. mailto:support@example.com">
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Card Image / Icon</label>
            <input type="file" name="image" accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
        </div>

        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition mt-4">Add Card</button>
    </form>
</div>

<!-- Existing Contact Cards -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-solid fa-address-card text-gray-500 mr-2"></i> Current Contact Cards</h3>
    
    <% if(cards && cards.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% cards.forEach(item => { %>
                <div class="border border-gray-200 rounded-xl p-6 bg-gray-50 relative flex flex-col">
                    <% if(item.image_url) { %>
                        <img src="<%= item.image_url %>" class="w-16 h-16 object-contain mb-4 bg-white p-2 rounded-lg shadow-sm" alt="Icon">
                    <% } %>
                    <p class="text-xs font-bold text-gray-400 uppercase mb-1"><%= item.subtitle || '---' %></p>
                    <h4 class="text-xl font-bold text-gray-800 mb-2"><%= item.title %></h4>
                    <p class="text-sm text-gray-600 mb-4 flex-1"><%= item.description %></p>
                    
                    <div class="mb-4">
                        <span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded font-bold"><%= item.button_text || 'No Button' %></span>
                        <p class="text-xs text-gray-500 mt-1 truncate" title="<%= item.button_link %>"><i class="fa-solid fa-link"></i> <%= item.button_link || '#' %></p>
                    </div>
                    
                    <div class="flex items-center gap-2 pt-4 border-t border-gray-200 mt-auto">
                        <a href="/admin/contact-page/card/edit/<%= item.id %>" class="flex-1 text-center text-blue-600 bg-blue-50 hover:bg-blue-100 py-2 rounded transition text-sm font-bold">
                            <i class="fa-solid fa-pen"></i> Edit
                        </a>
                        <form action="/admin/contact-page/card/delete/<%= item.id %>" method="POST" class="flex-1" onsubmit="return confirm('Delete this card permanently?');">
                            <button type="submit" class="w-full text-red-600 bg-red-50 hover:bg-red-100 py-2 rounded transition text-sm font-bold">
                                <i class="fa-solid fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-8 bg-gray-50 rounded-lg border border-dashed border-gray-300">
            <i class="fa-solid fa-address-card text-3xl text-gray-400 mb-2 block"></i>
            <p class="text-gray-500">No contact cards added yet.</p>
        </div>
    <% } %>
</div>

<%- include('includes/footer') %>
