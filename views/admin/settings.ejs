<%- include('includes/header') %>

<!-- Quill Rich Text Editor -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.js"></script>

<div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Site Settings</h1>
</div>

<% if (success) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        Settings updated successfully!
    </div>
<% } %>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <form method="POST" action="/admin/settings" enctype="multipart/form-data" class="space-y-6" id="settings-form">
        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Brand Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Site Name</label>
                    <input type="text" name="site_name" value="<%= settings['site_name'] %>" class="w-full border rounded px-3 py-2">
                </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Homepage Hero Section</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-gray-50 p-4 rounded-lg border border-gray-200">
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-sm font-medium mb-1">Badge Text (Top)</label>
                    <input type="text" name="hero_badge_text" value="<%= settings['hero_badge_text'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-sm font-medium mb-1">Hero Image</label>
                    <input type="file" name="hero_image" accept="image/*" class="w-full border rounded px-3 py-2 bg-white">
                    <% if(settings['hero_image']) { %>
                        <p class="text-xs text-gray-500 mt-1">Current: <a href="<%= settings['hero_image'] %>" target="_blank" class="text-blue-500 underline"><%= settings['hero_image'].split('/').pop() %></a></p>
                    <% } %>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium mb-1">Hero Title (HTML allowed for styling)</label>
                    <textarea name="hero_title" rows="2" class="w-full border rounded px-3 py-2 font-mono text-sm"><%= settings['hero_title'] %></textarea>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium mb-1">Hero Subtitle (HTML allowed for styling)</label>
                    <textarea name="hero_subtitle" rows="3" class="w-full border rounded px-3 py-2 font-mono text-sm"><%= settings['hero_subtitle'] %></textarea>
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-sm font-medium mb-1">Button 1 Text (Download)</label>
                    <input type="text" name="hero_button1_text" value="<%= settings['hero_button1_text'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-sm font-medium mb-1">Button 2 Text (Learn More)</label>
                    <input type="text" name="hero_button2_text" value="<%= settings['hero_button2_text'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium mb-1">Bonus Text (Below buttons)</label>
                    <input type="text" name="hero_bonus_text" value="<%= settings['hero_bonus_text'] %>" class="w-full border rounded px-3 py-2">
                </div>
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Mobile Applications</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-blue-50 p-4 rounded-lg border border-blue-100">
                <div>
                    <label class="block text-sm font-semibold mb-1 text-blue-800"><i class="fa-brands fa-android mr-1"></i> Android APK Download Link</label>
                    <p class="text-xs text-blue-600 mb-3">Linked to "Download App", "Play Now", and footer buttons.</p>
                    <input type="text" name="apk_file_url" value="<%= settings['apk_file_url'] !== '#' ? settings['apk_file_url'] : '' %>" placeholder="https://example.com/app.apk" class="w-full border border-blue-200 rounded px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <% if(settings['apk_file_url'] && settings['apk_file_url'] !== '#') { %>
                        <p class="text-sm mt-3 text-green-700 font-medium"><i class="fa-solid fa-circle-check"></i> Currently Active: <a href="<%= settings['apk_file_url'] %>" target="_blank" class="underline truncate inline-block align-bottom max-w-[200px]"><%= settings['apk_file_url'] %></a></p>
                    <% } %>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-1 text-blue-800"><i class="fa-brands fa-apple mr-1"></i> iOS App Store Link</label>
                    <p class="text-xs text-blue-600 mb-3">Linked exclusively to the App Store button in the footer.</p>
                    <input type="text" name="ios_app_url" value="<%= settings['ios_app_url'] !== '#' ? settings['ios_app_url'] : '' %>" placeholder="https://apps.apple.com/..." class="w-full border border-blue-200 rounded px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <% if(settings['ios_app_url'] && settings['ios_app_url'] !== '#') { %>
                        <p class="text-sm mt-3 text-green-700 font-medium"><i class="fa-solid fa-circle-check"></i> Currently Active: <a href="<%= settings['ios_app_url'] %>" target="_blank" class="underline truncate inline-block align-bottom max-w-[200px]"><%= settings['ios_app_url'] %></a></p>
                    <% } %>
                </div>
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">About Us Content</h3>
            <div class="space-y-2">
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium">Homepage About Us Text (Rich Content)</label>
                    <button type="button" id="about-toggle" onclick="toggleEditor('about')" class="text-xs text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1 transition">
                        <i class="fa-solid fa-expand text-[10px]"></i> Click to Edit
                    </button>
                </div>
                <div id="about-editor-wrap" class="relative border rounded-lg overflow-hidden transition-all duration-300" style="height: 80px;">
                    <div id="about-editor" style="background: white; height: 100%;"></div>
                    <div id="about-overlay" onclick="toggleEditor('about')" class="absolute inset-0 bg-white/60 backdrop-blur-[1px] flex items-center justify-center cursor-pointer group z-10">
                        <span class="text-sm text-gray-500 font-semibold group-hover:text-blue-600 transition"><i class="fa-solid fa-pen mr-1"></i>Click to expand and edit</span>
                    </div>
                </div>
                <input type="hidden" name="about_us_content" id="about-content">
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Contact Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Email</label>
                    <input type="email" name="contact_email" value="<%= settings['contact_email'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Phone</label>
                    <input type="text" name="contact_phone" value="<%= settings['contact_phone'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium mb-1">Corporate Address</label>
                    <textarea name="address" rows="2" class="w-full border rounded px-3 py-2"><%= settings['address'] %></textarea>
                </div>
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Social Media Links</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-facebook text-blue-600"></i> Facebook</label>
                    <input type="url" name="social_facebook" value="<%= settings['social_facebook'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-twitter text-blue-400"></i> Twitter</label>
                    <input type="url" name="social_twitter" value="<%= settings['social_twitter'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-instagram text-pink-600"></i> Instagram</label>
                    <input type="url" name="social_instagram" value="<%= settings['social_instagram'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-telegram text-blue-500"></i> Telegram</label>
                    <input type="url" name="social_telegram" value="<%= settings['social_telegram'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-whatsapp text-green-500"></i> WhatsApp</label>
                    <input type="url" name="social_whatsapp" value="<%= settings['social_whatsapp'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-youtube text-red-600"></i> YouTube</label>
                    <input type="url" name="social_youtube" value="<%= settings['social_youtube'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-brands fa-x-twitter text-gray-800"></i> X</label>
                    <input type="url" name="social_x" value="<%= settings['social_x'] %>" class="w-full border rounded px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1"><i class="fa-solid fa-bullhorn text-blue-400"></i> Telegram Channel</label>
                    <input type="url" name="social_telegram_channel" value="<%= settings['social_telegram_channel'] %>" class="w-full border rounded px-3 py-2">
                </div>
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Privacy Policy</h3>
            <div class="space-y-2">
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium">Privacy Policy Content (Rich Content)</label>
                    <button type="button" id="privacy-toggle" onclick="toggleEditor('privacy')" class="text-xs text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1 transition">
                        <i class="fa-solid fa-expand text-[10px]"></i> Click to Edit
                    </button>
                </div>
                <p class="text-xs text-gray-500">This content will appear on the public <a href="/privacy-policy" target="_blank" class="text-blue-500 underline">/privacy-policy</a> page.</p>
                <div id="privacy-editor-wrap" class="relative border rounded-lg overflow-hidden transition-all duration-300" style="height: 80px;">
                    <div id="privacy-editor" style="background: white; height: 100%;"></div>
                    <div id="privacy-overlay" onclick="toggleEditor('privacy')" class="absolute inset-0 bg-white/60 backdrop-blur-[1px] flex items-center justify-center cursor-pointer group z-10">
                        <span class="text-sm text-gray-500 font-semibold group-hover:text-blue-600 transition"><i class="fa-solid fa-pen mr-1"></i>Click to expand and edit</span>
                    </div>
                </div>
                <input type="hidden" name="privacy_policy" id="privacy-content">
            </div>
        </div>

        <div>
            <h3 class="text-lg font-bold border-b pb-2 mb-4">Terms &amp; Conditions</h3>
            <div class="space-y-2">
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium">Terms &amp; Conditions Content (Rich Content)</label>
                    <button type="button" id="terms-toggle" onclick="toggleEditor('terms')" class="text-xs text-blue-600 hover:text-blue-800 font-semibold flex items-center gap-1 transition">
                        <i class="fa-solid fa-expand text-[10px]"></i> Click to Edit
                    </button>
                </div>
                <p class="text-xs text-gray-500">This content will appear on the public <a href="/terms-and-conditions" target="_blank" class="text-blue-500 underline">/terms-and-conditions</a> page.</p>
                <div id="terms-editor-wrap" class="relative border rounded-lg overflow-hidden transition-all duration-300" style="height: 80px;">
                    <div id="terms-editor" style="background: white; height: 100%;"></div>
                    <div id="terms-overlay" onclick="toggleEditor('terms')" class="absolute inset-0 bg-white/60 backdrop-blur-[1px] flex items-center justify-center cursor-pointer group z-10">
                        <span class="text-sm text-gray-500 font-semibold group-hover:text-blue-600 transition"><i class="fa-solid fa-pen mr-1"></i>Click to expand and edit</span>
                    </div>
                </div>
                <input type="hidden" name="terms_conditions" id="terms-content">
            </div>
        </div>

        <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded font-medium shadow-md hover:bg-blue-700 transition">Save All Settings</button>
    </form>
</div>

<script>
    const quill = new Quill('#about-editor', {
        theme: 'snow',
        modules: { toolbar: [['bold', 'italic', 'underline', 'strike'], [{ 'header': [1, 2, 3, false] }], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link'], ['clean']] },
        placeholder: 'Enter content for About Us section on homepage...'
    });

    const privacyQuill = new Quill('#privacy-editor', {
        theme: 'snow',
        modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'header': [2, 3, false] }], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link'], ['clean']] },
        placeholder: 'Enter your Privacy Policy content here...'
    });

    const termsQuill = new Quill('#terms-editor', {
        theme: 'snow',
        modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'header': [2, 3, false] }], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link'], ['clean']] },
        placeholder: 'Enter your Terms & Conditions content here...'
    });

    // Pre-fill content
    quill.root.innerHTML = `<%- (settings['about_us_content'] || '').replace(/`/g, '\\`') %>`;
    privacyQuill.root.innerHTML = `<%- (settings['privacy_policy'] || '').replace(/`/g, '\\`') %>`;
    termsQuill.root.innerHTML = `<%- (settings['terms_conditions'] || '').replace(/`/g, '\\`') %>`;

    // Toggle expand/collapse
    const editorState = { about: false, privacy: false, terms: false };
    function toggleEditor(name) {
        const wrap = document.getElementById(name + '-editor-wrap');
        const overlay = document.getElementById(name + '-overlay');
        const toggle = document.getElementById(name + '-toggle');
        editorState[name] = !editorState[name];
        if (editorState[name]) {
            wrap.style.height = '400px';
            overlay.style.display = 'none';
            toggle.innerHTML = '<i class="fa-solid fa-compress text-[10px]"></i> Collapse';
        } else {
            wrap.style.height = '80px';
            overlay.style.display = 'flex';
            toggle.innerHTML = '<i class="fa-solid fa-expand text-[10px]"></i> Click to Edit';
        }
    }

    // On form submit, copy Quill HTML to hidden inputs
    document.getElementById('settings-form').addEventListener('submit', function() {
        document.getElementById('about-content').value = quill.root.innerHTML;
        document.getElementById('privacy-content').value = privacyQuill.root.innerHTML;
        document.getElementById('terms-content').value = termsQuill.root.innerHTML;
    });
</script>

<%- include('includes/footer') %>
