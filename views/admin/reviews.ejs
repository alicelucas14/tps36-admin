<%- include('includes/header') %>

<div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Manage Reviews</h1>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <h3 class="text-lg font-bold mb-4"><%= typeof editItem !== 'undefined' && editItem ? 'Edit Review' : 'Add New Review' %></h3>
    <form method="POST" action="/admin/reviews" enctype="multipart/form-data" class="space-y-4">
        <% if(typeof editItem !== 'undefined' && editItem) { %>
            <input type="hidden" name="action" value="edit">
            <input type="hidden" name="id" value="<%= editItem.id %>">
            <input type="hidden" name="existing_image" value="<%= editItem.image_url %>">
        <% } %>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium mb-1">Reviewer Name</label>
                <input type="text" name="reviewer_name" value="<%= typeof editItem !== 'undefined' && editItem ? editItem.reviewer_name : '' %>" required class="w-full border rounded px-3 py-2">
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Rating (1-5)</label>
                <select name="rating" class="w-full border rounded px-3 py-2">
                    <option value="5" <%= typeof editItem !== 'undefined' && editItem && editItem.rating == 5 ? 'selected' : '' %>>5 Stars</option>
                    <option value="4" <%= typeof editItem !== 'undefined' && editItem && editItem.rating == 4 ? 'selected' : '' %>>4 Stars</option>
                    <option value="3" <%= typeof editItem !== 'undefined' && editItem && editItem.rating == 3 ? 'selected' : '' %>>3 Stars</option>
                    <option value="2" <%= typeof editItem !== 'undefined' && editItem && editItem.rating == 2 ? 'selected' : '' %>>2 Stars</option>
                    <option value="1" <%= typeof editItem !== 'undefined' && editItem && editItem.rating == 1 ? 'selected' : '' %>>1 Star</option>
                </select>
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium mb-1">Upload Image (Optional) <% if(typeof editItem !== 'undefined' && editItem && editItem.image_url) { %><span class="text-xs text-blue-500 font-normal ml-2">(Current: <%= editItem.image_url %>)</span><% } %></label>
            <input type="file" name="image" accept="image/*" class="w-full border rounded px-3 py-1 bg-gray-50 focus:outline-none">
        </div>
        <div>
            <label class="block text-sm font-medium mb-1">Comment</label>
            <textarea name="comment" required rows="3" class="w-full border rounded px-3 py-2"><%= typeof editItem !== 'undefined' && editItem ? editItem.comment : '' %></textarea>
        </div>
        <div class="flex items-center gap-4">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded font-medium"><%= typeof editItem !== 'undefined' && editItem ? 'Update Review' : 'Save Review' %></button>
            <% if(typeof editItem !== 'undefined' && editItem) { %>
                <a href="/admin/reviews" class="text-gray-500 hover:text-gray-700 font-medium">Cancel Edit</a>
            <% } %>
        </div>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Reviewer</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Rating</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            <% reviews.forEach(rev => { %>
            <tr>
                <td class="px-6 py-4 font-medium"><%= rev.reviewer_name %></td>
                <td class="px-6 py-4 text-yellow-500">
                    <% for(let i=0; i<rev.rating; i++) { %><i class="fa-solid fa-star"></i><% } %>
                </td>
                <td class="px-6 py-4 text-right">
                    <a href="/admin/reviews?edit_id=<%= rev.id %>" class="text-blue-500 hover:text-blue-700 mr-3"><i class="fa-solid fa-pen"></i></a>
                    <form method="POST" action="/admin/reviews" class="inline">
                        <input type="hidden" name="action" value="delete">
                        <input type="hidden" name="id" value="<%= rev.id %>">
                        <button type="submit" class="text-red-500 hover:text-red-700"><i class="fa-solid fa-trash"></i></button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('includes/footer') %>
