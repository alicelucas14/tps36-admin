<%- include('includes/header') %>

<div class="flex items-center gap-4 mb-8">
    <a href="/admin/contact-page" class="text-gray-400 hover:text-gray-600 transition"><i class="fa-solid fa-arrow-left"></i></a>
    <h2 class="text-2xl font-bold text-gray-800">Edit Contact Card</h2>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 max-w-3xl border-t-4 border-t-blue-500">
    <form action="/admin/contact-page/card/edit/<%= card.id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Subtitle (e.g. Instant Help)</label>
                <input type="text" name="subtitle" value="<%= card.subtitle %>"
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Title (e.g. Live Chat) *</label>
                <input type="text" name="title" value="<%= card.title %>" required
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800">
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
            <textarea name="description" rows="3"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800 resize-none"><%= card.description %></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Button Text</label>
                <input type="text" name="button_text" value="<%= card.button_text %>"
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Button Link</label>
                <input type="text" name="button_link" value="<%= card.button_link %>"
                    class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800">
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Card Image</label>
            <% if(card.image_url) { %>
                <div class="mb-4">
                    <img src="<%= card.image_url %>" alt="Current image" class="h-32 rounded-xl border border-gray-200 object-contain bg-gray-100 p-2">
                    <input type="hidden" name="existing_image" value="<%= card.image_url %>">
                </div>
            <% } %>
            <input type="file" name="image" accept="image/*"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 transition outline-none text-gray-800">
        </div>

        <div class="flex items-center gap-4 pt-6 border-t border-gray-100">
            <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-sm">
                <i class="fa-solid fa-save mr-2"></i> Save Changes
            </button>
            <a href="/admin/contact-page" class="px-6 py-3 rounded-xl font-medium text-gray-500 hover:bg-gray-100 transition">Cancel</a>
        </div>
    </form>
</div>

<%- include('includes/footer') %>
