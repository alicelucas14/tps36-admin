<%- include('includes/header') %>

<div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Manage Categories</h1>
</div>

<!-- Add/Edit Form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8 max-w-2xl">
    <h3 class="text-lg font-bold mb-4"><%= typeof editItem !== 'undefined' && editItem ? 'Edit Category' : 'Add New Category' %></h3>
    <form method="POST" action="/admin/categories" class="space-y-4">
        <% if(typeof editItem !== 'undefined' && editItem) { %>
            <input type="hidden" name="action" value="edit">
            <input type="hidden" name="id" value="<%= editItem.id %>">
        <% } %>
        <div>
            <label class="block text-sm font-medium mb-1">Category Name</label>
            <input type="text" name="name" value="<%= typeof editItem !== 'undefined' && editItem ? editItem.name : '' %>" required class="w-full border rounded px-3 py-2" placeholder="e.g. Sports, Rummy, Casino">
        </div>
        <div class="flex items-center gap-4">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded font-medium shadow-sm hover:bg-blue-700 transition">
                <%= typeof editItem !== 'undefined' && editItem ? 'Update Category' : 'Save Category' %>
            </button>
            <% if(typeof editItem !== 'undefined' && editItem) { %>
                <a href="/admin/categories" class="text-gray-500 hover:text-gray-700 font-medium">Cancel Edit</a>
            <% } %>
        </div>
    </form>
</div>

<!-- List -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden max-w-2xl">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase">Category Name</th>
                <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            <% categories.forEach(cat => { %>
            <tr>
                <td class="px-6 py-4 font-medium"><%= cat.name %></td>
                <td class="px-6 py-4 text-right">
                    <a href="/admin/categories?edit_id=<%= cat.id %>" class="text-blue-500 hover:text-blue-700 mr-3 transition"><i class="fa-solid fa-pen"></i></a>
                    <form method="POST" action="/admin/categories" class="inline" onsubmit="return confirm('Are you sure you want to delete this category? This might affect blogs assigned to it.')">
                        <input type="hidden" name="action" value="delete">
                        <input type="hidden" name="id" value="<%= cat.id %>">
                        <button type="submit" class="text-red-500 hover:text-red-700 transition"><i class="fa-solid fa-trash"></i></button>
                    </form>
                </td>
            </tr>
            <% }) %>
            <% if(categories.length === 0) { %>
                <tr><td colspan="2" class="px-6 py-8 text-center text-gray-400">No categories found.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('includes/footer') %>
