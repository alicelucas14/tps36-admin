<%- include('includes/header') %>

<div class="flex justify-between items-center mb-8">
    <div>
        <h1 class="text-3xl font-bold text-gray-800">Checkout Steps</h1>
        <p class="text-gray-500 mt-1">Manage the zig-zag steps shown on the public checkout page.</p>
    </div>
</div>

<!-- Add New Step -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8 border-l-4 border-l-blue-500">
    <h3 class="text-lg font-bold text-gray-800 mb-4"><i class="fa-solid fa-plus-circle text-blue-500 mr-2"></i> Add New Step</h3>
    <form action="/admin/checkout-steps" method="POST" enctype="multipart/form-data" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Step Number</label>
                <input type="number" name="step_number" value="<%= (steps && steps.length > 0) ? steps[steps.length - 1].step_number + 1 : 1 %>" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Step Title</label>
                <input type="text" name="title" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="e.g. Step 1">
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                <textarea name="description" rows="3" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Description of this step..."></textarea>
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Upload Image</label>
                <input type="file" name="image" accept="image/*" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
        </div>
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition mt-4">Add Step</button>
    </form>
</div>

<!-- Existing Steps -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2"><i class="fa-solid fa-list-ol text-gray-500 mr-2"></i> Current Steps</h3>
    
    <% if(steps && steps.length > 0) { %>
        <div class="grid grid-cols-1 gap-6">
            <% steps.forEach((step, index) => { %>
                <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition bg-gray-50 flex flex-col md:flex-row relative">
                    <div class="relative w-full md:w-48 h-48 bg-gray-200 flex-shrink-0">
                        <% if(step.image_url) { %>
                            <img src="<%= step.image_url %>" class="w-full h-full object-cover" alt="Step Image">
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center text-gray-400"><i class="fa-solid fa-image text-4xl"></i></div>
                        <% } %>
                    </div>
                    
                    <div class="p-6 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-2">
                            <h4 class="text-lg font-bold text-gray-800">
                                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded mr-2">Order: <%= step.step_number %></span>
                                <%= step.title %>
                            </h4>
                            <div class="flex items-center gap-2">
                                <a href="/admin/checkout-steps/edit/<%= step.id %>" class="text-blue-500 hover:text-blue-700 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded transition text-sm font-bold">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </a>
                                <form action="/admin/checkout-steps/delete/<%= step.id %>" method="POST" onsubmit="return confirm('Delete this step permanently?');">
                                    <button type="submit" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded transition text-sm font-bold">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                        <p class="text-gray-600 text-sm whitespace-pre-wrap"><%= step.description %></p>
                        <div class="mt-4 text-xs text-gray-400 font-mono">Layout Preview: <%= (index % 2 === 0) ? 'Text Left, Image Right' : 'Image Left, Text Right' %></div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-8 bg-gray-50 rounded-lg border border-dashed border-gray-300">
            <i class="fa-solid fa-cart-shopping text-3xl text-gray-400 mb-2 block"></i>
            <p class="text-gray-500">No checkout steps added yet.</p>
        </div>
    <% } %>
</div>

<%- include('includes/footer') %>
