    "pm2:logs": "pm2 logs teenpattistars"
  },
  "dependencies": {
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["cms", "teen-patti", "express", "ejs", "sqlite"],
